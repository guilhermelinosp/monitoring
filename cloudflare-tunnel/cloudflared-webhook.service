[Unit]
Description=Cloudflare Tunnel - webhook.hellnet.com.br
After=network-online.target
Wants=network-online.target

[Service]
TimeoutStartSec=15
Type=notify
ExecStart=/usr/bin/cloudflared --no-autoupdate tunnel --config /root/.cloudflared/webhook-config.yaml run
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
